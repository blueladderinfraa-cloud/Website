# Production Environment Variables Template
# Copy this file and fill in your production values

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000

# Database (Railway/hosting provider will usually provide this)
DATABASE_URL=your_database_url_here

# Admin Credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# JWT Secret (Generate a random string)
JWT_SECRET=your_random_jwt_secret_here

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/app/client/public/uploads

# Optional: Cloud Storage (if using AWS S3, Cloudflare R2, etc.)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=your_bucket_name

# Optional: Email Configuration (for contact form)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Optional: Google Maps API (if using maps)
# GOOGLE_MAPS_API_KEY=your_google_maps_key

# Domain Configuration
DOMAIN=https://yourdomain.com
